# Neon Postgres — pooled (runtime / Vercel)
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/neondb?sslmode=require&pgbouncer=true"

# Neon direct (Prisma migrate / db push)
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/neondb?sslmode=require"

# Auth session signing (required — long random string on Vercel)
AUTH_SECRET="change-me-to-a-long-random-secret"

# Admin account for seed / scripts/set-admin.ts (local + Neon)
ADMIN_EMAIL="admin@rfacto.ca"
ADMIN_PASSWORD="change-me-admin-password"

# Public app URL (OAuth / Stripe redirects) — production: https://rfacto.com
NEXT_PUBLIC_APP_URL="https://rfacto.com"

# Mobile CORS (comma-separated origins, or * for all — default *)
MOBILE_CORS_ORIGIN="*"

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (payments escrow + Identity KYC + Connect)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_FEE_BPS=1000

# Vercel Blob (avatars + parcel photos) — auto-set when you create a Blob store in Vercel Storage
BLOB_READ_WRITE_TOKEN=
# Match your store: private (default) or public
BLOB_ACCESS=private

# Transactional email (Resend) — optional; skipped if unset
RESEND_API_KEY=
EMAIL_FROM="Rfacto <onboarding@resend.dev>"

# Optional Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
