generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  SENDER
  TRAVELER
  BOTH
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum TripStatus {
  OPEN
  FULL
  COMPLETED
  CANCELLED
}

enum TransportMode {
  AIR
  SEA
  RAIL
  ROAD
}

enum RequestStatus {
  OPEN
  MATCHED
  CLOSED
  CANCELLED
}

enum Urgency {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum BookingStatus {
  PROPOSED
  AWAITING_PAYMENT
  ACCEPTED
  HANDED_OVER
  IN_TRANSIT
  DELIVERED
  CANCELLED
  REFUSED
}

enum KycStatus {
  NONE
  PENDING
  VERIFIED
  FAILED
  REQUIRES_INPUT
}

enum PaymentStatus {
  REQUIRES_PAYMENT
  AUTHORIZED
  CAPTURED
  CANCELLED
  REFUNDED
  FAILED
}

enum DisputeStatus {
  OPEN
  IN_REVIEW
  RESOLVED
  CLOSED
}

model Currency {
  id           String  @id @default(cuid())
  code         String  @unique
  name         String
  symbol       String
  exchangeRate Float   @default(1)
  active       Boolean @default(true)

  countries Country[]
}

model Language {
  id     String  @id @default(cuid())
  code   String  @unique
  name   String
  active Boolean @default(true)
}

model Country {
  id           String  @id @default(cuid())
  code         String  @unique
  name         String
  continent    String
  flagEmoji    String?
  currencyCode String?
  active       Boolean @default(true)

  currency Currency? @relation(fields: [currencyCode], references: [code])
  cities   City[]

  @@index([continent])
  @@index([name])
}

model City {
  id          String  @id @default(cuid())
  countryCode String
  name        String
  latitude    Float?
  longitude   Float?
  active      Boolean @default(true)

  country Country @relation(fields: [countryCode], references: [code], onDelete: Cascade)

  @@unique([countryCode, name])
  @@index([name])
}

model User {
  id                          String     @id @default(cuid())
  email                       String     @unique
  passwordHash                String?
  googleId                    String?    @unique
  displayName                 String
  avatarUrl                   String?
  country                     String?
  phone                       String?
  language                    String     @default("fr")
  preferredCurrency           String     @default("CAD")
  bio                         String?
  role                        UserRole   @default(BOTH)
  status                      UserStatus @default(ACTIVE)
  verifiedAt                  DateTime?
  ratingAvg                   Float      @default(0)
  ratingCount                 Int        @default(0)
  completedDeliveries         Int        @default(0)
  stripeCustomerId            String?    @unique
  stripeConnectAccountId      String?    @unique
  stripeConnectChargesEnabled Boolean    @default(false)
  stripeConnectPayoutsEnabled Boolean    @default(false)
  kycStatus                   KycStatus  @default(NONE)
  kycSessionId                String?
  kycVerifiedAt               DateTime?
  createdAt                   DateTime   @default(now())
  updatedAt                   DateTime   @updatedAt

  trips            Trip[]
  parcelRequests   ParcelRequest[]
  bookingsAsSender Booking[]       @relation("BookingSender")
  messages         Message[]
  reviewsGiven     Review[]        @relation("ReviewsGiven")
  reviewsReceived  Review[]        @relation("ReviewsReceived")
  reportsFiled     Report[]        @relation("ReportsFiled")
  reportsAgainst   Report[]        @relation("ReportsAgainst")
  disputesOpened   Dispute[]       @relation("DisputesOpened")
  disputesAgainst  Dispute[]       @relation("DisputesAgainst")
  passwordResets   PasswordResetToken[]
  notifications    Notification[]
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  type      String
  title     String
  body      String
  href      String?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, readAt])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}

model Trip {
  id            String     @id @default(cuid())
  userId        String
  fromCountry   String
  fromCity      String
  toCountry     String
  toCity        String
  departAt      DateTime
  weightKg      Float
  pricePerKgCad Float
  currency      String     @default("CAD")
  /// If true, senders can counter-offer a price per kg; traveler may talk to several parties.
  priceNegotiable Boolean  @default(false)
  acceptedGoods String
  notes           String?
  transportMode   TransportMode @default(AIR)
  airline         String?
  flightNumber    String?
  fromAirportCode String?
  toAirportCode   String?
  status          TripStatus @default(OPEN)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([fromCountry, toCountry, departAt])
  @@index([toCountry, toCity, departAt])
  @@index([userId])
  @@index([transportMode])
}

model ParcelRequest {
  id            String        @id @default(cuid())
  userId        String
  fromCountry   String
  fromCity      String
  toCountry     String
  toCity        String
  weightKg      Float
  description   String
  photosJson    String        @default("[]")
  urgency       Urgency       @default(NORMAL)
  declaredValue Float?
  desiredDate   DateTime?
  status        RequestStatus @default(OPEN)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings Booking[]

  @@index([toCountry, toCity])
  @@index([userId])
}

model Booking {
  id                  String        @id @default(cuid())
  requestId           String
  tripId              String
  senderId            String
  /// Who started the mise en relation: SENDER (propose) or TRAVELER (apply)
  proposedBy          String        @default("SENDER")
  status              BookingStatus @default(PROPOSED)
  goodsCertified      Boolean       @default(false)
  customsAcknowledged Boolean       @default(false)
  /// Sender counter-offer (per kg, same currency as trip). Used when trip.priceNegotiable.
  offeredPricePerKg   Float?
  handoverToken       String?       @unique
  handoverCode        String?
  handoverExpiresAt   DateTime?
  handedOverAt        DateTime?
  /// Deadline to complete Stripe checkout (24h after AWAITING_PAYMENT)
  paymentExpiresAt    DateTime?
  cancelledReason     String?
  cancelledById       String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  request  ParcelRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  trip     Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  sender   User          @relation("BookingSender", fields: [senderId], references: [id], onDelete: Cascade)
  messages  Message[]
  reviews   Review[]
  payment   Payment?
  events    BookingEvent[]
  locations BookingLocation[]
  disputes  Dispute[]

  @@unique([requestId, tripId])
  @@index([senderId])
  @@index([status])
  @@index([handoverCode])
  @@index([paymentExpiresAt])
}

model BookingEvent {
  id        String   @id @default(cuid())
  bookingId String
  type      String
  status    String?
  label     String
  metaJson  String   @default("{}")
  actorId   String?
  createdAt DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
}

model BookingLocation {
  id         String   @id @default(cuid())
  bookingId  String
  userId     String
  latitude   Float
  longitude  Float
  accuracyM  Float?
  label      String?
  createdAt  DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
}

model Payment {
  id                     String        @id @default(cuid())
  bookingId              String        @unique
  amountCadCents         Int
  platformFeeCents       Int
  travelerPayoutCents    Int
  currency               String        @default("cad")
  provider               String        @default("stripe")
  status                 PaymentStatus @default(REQUIRES_PAYMENT)
  stripePaymentIntentId  String?       @unique
  stripeCheckoutSessionId String?      @unique
  stripeTransferId       String?
  createdAt              DateTime      @default(now())
  updatedAt              DateTime      @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([status])
}

model CorridorConfig {
  id              String  @id @default(cuid())
  fromCountry     String
  toCountry       String
  currency        String  @default("cad")
  feeBps          Int     @default(1000)
  active          Boolean @default(true)
  paymentProvider String  @default("stripe")

  @@unique([fromCountry, toCountry])
  @@index([active])
}

model StripeEvent {
  id          String   @id @default(cuid())
  eventId     String   @unique
  type        String
  processedAt DateTime @default(now())
}

model Message {
  id            String   @id @default(cuid())
  bookingId     String
  senderId      String
  body          String
  attachmentUrl String?
  createdAt     DateTime @default(now())

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  sender  User    @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
}

model Review {
  id         String   @id @default(cuid())
  bookingId  String
  fromUserId String
  toUserId   String
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())

  booking  Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  fromUser User    @relation("ReviewsGiven", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser   User    @relation("ReviewsReceived", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([bookingId, fromUserId])
  @@index([toUserId])
}

model Report {
  id           String   @id @default(cuid())
  reporterId   String
  targetUserId String
  reason       String
  details      String?
  resolved     Boolean  @default(false)
  createdAt    DateTime @default(now())

  reporter   User @relation("ReportsFiled", fields: [reporterId], references: [id], onDelete: Cascade)
  targetUser User @relation("ReportsAgainst", fields: [targetUserId], references: [id], onDelete: Cascade)

  @@index([resolved])
}

model Dispute {
  id            String        @id @default(cuid())
  bookingId     String
  openedById    String
  againstUserId String
  reason        String
  details       String?
  status        DisputeStatus @default(OPEN)
  adminNote     String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  resolvedAt    DateTime?

  booking     Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  openedBy    User    @relation("DisputesOpened", fields: [openedById], references: [id], onDelete: Cascade)
  againstUser User    @relation("DisputesAgainst", fields: [againstUserId], references: [id], onDelete: Cascade)

  @@index([bookingId, createdAt])
  @@index([status])
  @@index([openedById])
}
